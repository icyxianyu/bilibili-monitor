# Bilibili
BILIBILI_COOKIE=          # 可选，提升 API 限速上限

# LLM (OpenAI 兼容接口)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# 推送通知
WEBHOOK_URL=              # 可选，Webhook 接收地址
WEBHOOK_SECRET=           # 可选，HMAC-SHA256 签名密钥

# 服务配置
HTTP_PORT=3000
CORS_ORIGIN=http://localhost:3001

# 数据库 (SQLite 文件路径)
DATABASE_URL=./data/monitor.db
